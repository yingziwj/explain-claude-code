---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	canonical: string;
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, canonical, structuredData } = Astro.props;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT?.trim() || '';
const ogImage = new URL('/social-card.svg', canonical).toString();
const pageUrl = new URL(canonical);
const siteUrl = Astro.site?.toString() || `${pageUrl.origin}/`;
const pathname = pageUrl.pathname.replace(/\/$/, '') || '/';
const pageName = title.replace(/\s*\|\s*通俗版 Claude Code 文档$/, '');
const pathSegments = pathname === '/' ? [] : pathname.split('/').filter(Boolean);
const labelMap: Record<string, string> = {
	guides: '原创指南',
	docs: '文档解释',
	en: 'English Docs'
};
const breadcrumbItems = [
	{
		'@type': 'ListItem',
		position: 1,
		name: '首页',
		item: siteUrl
	}
];

let runningPath = '';
for (const segment of pathSegments) {
	runningPath += `/${segment}`;
	breadcrumbItems.push({
		'@type': 'ListItem',
		position: breadcrumbItems.length + 1,
		name: labelMap[segment] || decodeURIComponent(segment).replace(/-/g, ' '),
		item: new URL(runningPath, siteUrl).toString()
	});
}

if (breadcrumbItems[breadcrumbItems.length - 1]?.name !== pageName) {
	breadcrumbItems.push({
		'@type': 'ListItem',
		position: breadcrumbItems.length + 1,
		name: pageName,
		item: canonical
	});
}

const defaultStructuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: '通俗版 Claude Code 文档',
		url: siteUrl,
		description
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: '通俗版 Claude Code 文档',
		url: siteUrl,
		description: '第三方非官方 Claude Code 中文解释与原创实战指南站点',
		contactPoint: {
			'@type': 'ContactPoint',
			contactType: 'customer support',
			url: new URL('/contact', siteUrl).toString()
		},
		sameAs: [
			'https://github.com/yingziwj/explain-claude-code',
			'https://github.com/yingziwj/explain-claude-code/issues'
		]
	},
	{
		'@context': 'https://schema.org',
		'@type': pathname.startsWith('/guides/') ? 'Article' : 'WebPage',
		headline: pageName,
		name: pageName,
		description,
		url: canonical,
		isPartOf: {
			'@type': 'WebSite',
			name: '通俗版 Claude Code 文档',
			url: siteUrl
		}
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: breadcrumbItems
	}
];
const pageStructuredData = structuredData
	? [...defaultStructuredData, ...(Array.isArray(structuredData) ? structuredData : [structuredData])]
	: defaultStructuredData;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="robots" content="index,follow,max-image-preview:large" />
		<meta name="theme-color" content="#f6efe3" />
		<link rel="canonical" href={canonical} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="zh_CN" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="通俗版 Claude Code 文档" />
		<meta property="og:image" content={ogImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		{adsenseClient ? <meta name="google-adsense-account" content={adsenseClient} /> : null}
		<script type="application/ld+json" set:html={JSON.stringify(pageStructuredData)} />
		{
			adsenseClient ? (
				<script
					async
					src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
					crossorigin="anonymous"
				></script>
			) : null
		}
	</head>
	<body>
		<div class="site-frame">
			<slot />
			<footer class="site-footer">
				<div class="site-footer__inner">
					<div class="site-footer__copy">
						<strong>通俗版 Claude Code 文档</strong>
						<p>第三方非官方解释站，尽量把官方 docs 讲成人能照着做的话。</p>
					</div>
					<nav class="site-footer__nav" aria-label="站点页脚">
						<a href="/guides">原创指南</a>
						<a href="/about">关于本站</a>
						<a href="/contact">联系本站</a>
						<a href="/privacy">隐私说明</a>
						<a href="/terms">使用条款</a>
						<a href="/advertising">广告说明</a>
					</nav>
				</div>
			</footer>
		</div>
	</body>
</html>
