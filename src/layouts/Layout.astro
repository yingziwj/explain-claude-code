---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { navSections } from '../data/navigation';

interface Props {
	title: string;
	description: string;
	pathname: string;
}

const { title, description, pathname } = Astro.props;
const canonical = new URL(pathname, Astro.site);
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT?.trim() || '';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta property="og:image" content={new URL('/social-card.svg', Astro.site)} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="zh_CN" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="通俗版 Claude Code 文档" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content={new URL('/social-card.svg', Astro.site)} />
		{adsenseClient ? <meta name="google-adsense-account" content={adsenseClient} /> : null}
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'WebSite',
			name: '通俗版 Claude Code 文档',
			url: Astro.site,
			description
		})} />
		<script is:inline>
			const saved = localStorage.getItem('theme');
			const preferredDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			const isDark = saved ? saved === 'dark' : preferredDark;
			document.documentElement.classList.toggle('dark', isDark);
		</script>
		{
			adsenseClient ? (
				<script
					async
					src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
					crossorigin="anonymous"
				></script>
			) : null
		}
	</head>
	<body>
		<div class="mx-auto grid min-h-screen max-w-[1600px] gap-6 px-4 py-4 lg:grid-cols-[320px_minmax(0,1fr)]">
			<Sidebar sections={navSections} currentPath={pathname} />
			<div class="space-y-6">
				<header class="card rounded-[28px] px-6 py-5 shadow-card">
					<div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
						<div class="flex items-center gap-4">
							<img src="/logo.svg" alt="农民伯伯抱着 Claude 图标" class="h-14 w-14 rounded-2xl" />
							<div>
								<p class="font-display text-2xl font-semibold">讲给长辈听的 Claude Code</p>
								<p class="text-sm" style="color: var(--muted);">保留原导航结构，逐页翻成能听懂的大白话。</p>
							</div>
						</div>
						<ThemeToggle />
					</div>
				</header>
				<main>
					<slot />
				</main>
				<footer class="card rounded-[28px] px-6 py-5 shadow-card">
					<div class="flex flex-col gap-3 text-sm md:flex-row md:items-center md:justify-between">
						<p style="color: var(--muted);">文档做成大白话，广告和隐私说明也提前备好，方便后面正式接 AdSense。</p>
						<div class="flex flex-wrap gap-4" style="color: var(--muted);">
							<a href="/privacy" class="underline decoration-dotted underline-offset-4">隐私说明</a>
							<a href="/advertising" class="underline decoration-dotted underline-offset-4">广告说明</a>
						</div>
					</div>
				</footer>
			</div>
		</div>
	</body>
</html>
