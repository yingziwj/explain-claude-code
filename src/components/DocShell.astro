---
import AdSlot from './AdSlot.astro';
import type { SiteData, SitePage } from '../data/site-data';

const { page, siteData, currentPath } = Astro.props as {
	page: SitePage;
	siteData: SiteData;
	currentPath: string;
};

const currentSection = siteData.sections.find((section) => section.key === page.sectionKey) ?? siteData.sections[0];
const summarySection = page.content.sections.find((section) => section.title === '简要总结');
const explainSection = page.content.sections.find((section) => section.title === '农民伯伯版解释');
const practiceSection = page.content.sections.find((section) => section.title === '上手时重点盯住什么');
const mainSections = page.content.sections.filter((section) => !['简要总结', '农民伯伯版解释', '上手时重点盯住什么'].includes(section.title));
const showAdPlaceholders = !import.meta.env.PUBLIC_ADSENSE_CLIENT;

function stepKindLabel(kind?: string) {
	if (kind === 'command') return '终端里敲';
	if (kind === 'config') return '改配置';
	if (kind === 'prompt') return '直接对 Claude 说';
	if (kind === 'structure') return '目录怎么摆';
	return '关键片段';
}
---

<div class="doc-shell">
	<header class="doc-topbar">
		<a class="doc-brand" href="/">
			<img src="/logo.svg" alt="农民伯伯抱着 Claude 图标" class="doc-brand__logo" />
			<div>
				<strong>通俗版 Claude Code 文档</strong>
				<p>结构照原 docs，内容改成真能照着做的人话版。</p>
			</div>
		</a>
	</header>

	<div class="doc-grid">
		<aside class="doc-sidebar" aria-label="侧边导航">
			<div class="doc-sidebar__intro">
				<p class="doc-eyebrow">全部目录</p>
				<p>一级是官方栏目，下面挂的是这个栏目里的页面，顺序也照官方来。</p>
			</div>
			{siteData.sections.map((section) => (
				<section class={`doc-sidebar__group ${section.key === currentSection?.key ? 'is-current' : ''}`}>
					<h2>
						<a href={section.href} class={section.key === currentSection?.key ? 'active' : ''}>{section.title}</a>
					</h2>
					<ul>
						{section.items.map((item) => (
							<li>
								<a href={item.href} class={item.actualPath === currentPath ? 'active' : ''}>
									{item.title}
								</a>
							</li>
						))}
					</ul>
				</section>
			))}

			<AdSlot slot={import.meta.env.PUBLIC_ADSENSE_SIDEBAR_SLOT} position="侧边栏" format="vertical" />
		</aside>

		<main class="doc-main">
			<div class="doc-meta">
				<a href={page.sourceUrl} target="_blank" rel="noreferrer">查看原始文档</a>
				<span>目录顺序与官方保持一致</span>
			</div>

			<article class="doc-article">
				<header class="doc-hero">
					<p class="doc-eyebrow">{page.sectionTitle}</p>
					<h1>{page.title}</h1>
					<p class="doc-hero__summary">{page.summary}</p>
				</header>

				<section class="doc-panel">
					<p class="doc-eyebrow">这一页先讲明白</p>
					<div class="doc-copy">
						{summarySection?.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
						{explainSection?.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
						{practiceSection?.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
					</div>
					{practiceSection?.steps?.length ? (
						<div class="doc-steps">
							{practiceSection.steps.map((step) => (
								<div class="doc-step">
									<div class="doc-step__head">
										{step.kind ? <span class={`doc-step__tag doc-step__tag--${step.kind}`}>{stepKindLabel(step.kind)}</span> : null}
										<h3>{step.title}</h3>
									</div>
									<p>{step.body}</p>
									{step.code ? <pre><code>{step.code}</code></pre> : null}
								</div>
							))}
						</div>
					) : null}
				</section>

				{showAdPlaceholders ? (
					<section class="doc-ad-placeholder">
						<p>预留广告位</p>
						<strong>正文中段响应式广告</strong>
						<span>等你后面真接 AdSense，这里再放正式广告。</span>
					</section>
				) : (
					<AdSlot slot={import.meta.env.PUBLIC_ADSENSE_CONTENT_SLOT} position="正文中段" format="horizontal" />
				)}

				{mainSections.map((section) => (
					<section class="doc-panel">
						<p class="doc-eyebrow">{section.title}</p>
						<div class="doc-copy">
							{section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
						</div>
						{section.steps?.length ? (
							<div class="doc-steps">
								{section.steps.map((step) => (
									<div class="doc-step">
										<div class="doc-step__head">
											{step.kind ? <span class={`doc-step__tag doc-step__tag--${step.kind}`}>{stepKindLabel(step.kind)}</span> : null}
											<h3>{step.title}</h3>
										</div>
										<p>{step.body}</p>
										{step.code ? <pre><code>{step.code}</code></pre> : null}
									</div>
								))}
							</div>
						) : null}
					</section>
				))}

				<section class="doc-panel doc-panel--illustration">
					<p class="doc-eyebrow">{page.content.illustration.title}</p>
					<div class="doc-copy">
						<p>{page.content.illustration.caption}</p>
					</div>
					<pre class="doc-illustration"><code>{page.content.illustration.lines.join('\n')}</code></pre>
				</section>

				<section class="doc-panel">
					<p class="doc-eyebrow">文末提醒</p>
					<div class="doc-copy">
						<p>这站会按官方 docs 的导航和内容变化继续重生成，原站加页、删页、改页时，这里会跟着更新。</p>
						<p>人话解释会尽量顺着原页往下讲，但命令、参数名、配置名这些硬东西还是保留原样，免得你抄过去跑不起来。</p>
					</div>
				</section>

				{showAdPlaceholders ? (
					<section class="doc-ad-placeholder doc-ad-placeholder--footer">
						<p>预留广告位</p>
						<strong>文末横幅广告</strong>
						<span>适合放在文章读完以后，不抢首屏注意力。</span>
					</section>
				) : (
					<AdSlot slot={import.meta.env.PUBLIC_ADSENSE_CONTENT_SLOT} position="文末" format="horizontal" />
				)}
			</article>
		</main>
	</div>
</div>
