---
import DocContentPage from '../../../components/DocContentPage.astro';
import Layout from '../../../layouts/Layout.astro';
import { getDocContent } from '../../../data/doc-content';
import { allDocs, getDocBySlug } from '../../../data/navigation';

export function getStaticPaths() {
	return allDocs.map((doc) => ({
		params: { slug: doc.slug }
	}));
}

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam ?? '';
const doc = getDocBySlug(slug);

if (!doc) {
	throw new Error(`Unknown doc slug: ${slug}`);
}

const content = getDocContent(doc);
---

<Layout title={`${doc.title} | 通俗版 Claude Code 文档`} description={doc.summary} pathname={doc.path}>
	<DocContentPage
		title={doc.title}
		summary={doc.summary}
		section={doc.section}
		sourceUrl={`https://code.claude.com/docs/en/${doc.slug}`}
		content={content}
	/>
</Layout>
