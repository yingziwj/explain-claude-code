---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DocShell from '../../../components/DocShell.astro';
import { siteData, getSitePageBySlug } from '../../../data/site-data';

export function getStaticPaths() {
	return siteData.pages.map((doc) => ({
		params: { slug: doc.slug }
	}));
}

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam ?? '';
const doc = getSitePageBySlug(slug);

if (!doc) {
	throw new Error(`Unknown doc slug: ${slug}`);
}
const canonical = new URL(doc.path, Astro.site).toString();
---

<BaseLayout
	title={`${doc.title} | 通俗版 Claude Code 文档`}
	description={doc.summary}
	canonical={canonical}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'TechArticle',
		headline: doc.title,
		description: doc.summary,
		url: canonical,
		about: 'Claude Code documentation',
		isBasedOn: doc.sourceUrl
	}}
>
	<DocShell page={doc} siteData={siteData} currentPath={doc.path} />
</BaseLayout>
