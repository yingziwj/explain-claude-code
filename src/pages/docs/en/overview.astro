---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DocShell from '../../../components/DocShell.astro';
import { getSitePageBySlug, siteData } from '../../../data/site-data';

const doc = getSitePageBySlug('overview');

if (!doc) {
	throw new Error('Overview doc metadata is missing');
}
const canonical = new URL(doc.path, Astro.site).toString();
---

<BaseLayout title={`${doc.title} | 通俗版 Claude Code 文档`} description={doc.summary} canonical={canonical}>
	<DocShell page={doc} siteData={siteData} currentPath={doc.path} />
</BaseLayout>
