---
import DocContentPage from '../../../components/DocContentPage.astro';
import Layout from '../../../layouts/Layout.astro';
import { getDocContent } from '../../../data/doc-content';
import { getDocBySlug } from '../../../data/navigation';

const doc = getDocBySlug('overview');

if (!doc) {
	throw new Error('Overview doc metadata is missing');
}

const content = getDocContent(doc);
---

<Layout title={`${doc.title} | 通俗版 Claude Code 文档`} description={doc.summary} pathname={doc.path}>
	<DocContentPage
		title={doc.title}
		summary={doc.summary}
		section={doc.section}
		sourceUrl="https://code.claude.com/docs/en/overview"
		content={content}
	/>
</Layout>
